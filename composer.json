{
    "name": "liquidlab-agency/magento2-urgent-cargus",
    "type": "magento2-component",
    "license": "proprietary",
    "description": "Community-maintained Cargus shipping integration for Magento 2 (metapackage). Fork of the original Cargus/Tremend module, updated for Magento 2.4.x and PHP 8.2/8.3.",
    "keywords": [
        "magento2",
        "magento-2",
        "cargus",
        "shipping",
        "courier",
        "romania",
        "awb",
        "ecommerce"
    ],
    "homepage": "https://github.com/liquidlab-agency/magento2-urgent-cargus",
    "support": {
        "issues": "https://github.com/liquidlab-agency/magento2-urgent-cargus/issues",
        "source": "https://github.com/liquidlab-agency/magento2-urgent-cargus"
    },
    "authors": [
        {
            "name": "Alexandru Marinescu",
            "email": "alexandru.marinescu@tremend.com",
            "role": "Original author (Tremend Software Consulting)"
        },
        {
            "name": "LiquidLab",
            "homepage": "https://github.com/liquidlab-agency",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3",
        "magento/framework": "^103.0"
    },
    "autoload": {
        "files": [
            "src/Base/registration.php",
            "src/Cargus/registration.php",
            "src/CargusOldAwb/registration.php",
            "src/CargusShipGo/registration.php"
        ],
        "psr-4": {
            "Urgent\\Base\\": "src/Base",
            "Urgent\\Cargus\\": "src/Cargus",
            "Urgent\\CargusOldAwb\\": "src/CargusOldAwb",
            "Urgent\\CargusShipGo\\": "src/CargusShipGo"
        }
    },
    "replace": {
        "liquidlab-agency/module-base": "*",
        "liquidlab-agency/module-cargus": "*",
        "liquidlab-agency/module-cargus-old-awb": "*",
        "liquidlab-agency/module-cargusshipgo": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "magento/magento-composer-installer": true,
            "magento/inventory-composer-installer": true
        }
    }
}